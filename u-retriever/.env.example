# =============================================================================
# AUTHENTICATION
# =============================================================================

# Mode: "oauth" or "api_key"
AUTH_MODE=api_key

# API key auth (when AUTH_MODE=api_key)
OPENAI_API_KEY=sk-...

# OAuth auth (when AUTH_MODE=oauth)
OAUTH_TOKEN_ENDPOINT=https://auth.example.com/oauth2/token
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPE=

# =============================================================================
# LLM ENDPOINT
# =============================================================================

LLM_ENDPOINT=https://api.openai.com/v1

# =============================================================================
# LLM MODELS -- per stage
# Each stage uses {STAGE}_MODEL, {STAGE}_MAX_TOKENS, {STAGE}_TEMPERATURE,
# and optionally {STAGE}_REASONING_EFFORT.
#
# TEMPERATURE: Leave blank for models that don't support it (gpt-5-*, o-series)
# REASONING_EFFORT: Controls thinking depth. Values depend on your deployment:
#   - OpenAI public API: minimal, medium, high
#   - Azure deployments: may use low, medium, high instead
#   - Leave blank for default model behavior
# =============================================================================

# Startup -- connection validation only
STARTUP_MODEL=gpt-5-mini
STARTUP_MAX_TOKENS=100
STARTUP_TEMPERATURE=
STARTUP_REASONING_EFFORT=low

# Query preparation -- rewriting, decomposition, HyDE
QUERY_PREP_MODEL=gpt-5-mini
QUERY_PREP_MAX_TOKENS=1600
QUERY_PREP_TEMPERATURE=
QUERY_PREP_REASONING_EFFORT=low

# Reranking -- score and filter search results
RERANK_MODEL=gpt-5-mini
RERANK_MAX_TOKENS=900
RERANK_TEMPERATURE=
RERANK_REASONING_EFFORT=medium

# Research -- iterative analysis of retrieved content
RESEARCH_MODEL=gpt-5-mini
RESEARCH_MAX_TOKENS=32768
RESEARCH_TEMPERATURE=
RESEARCH_REASONING_EFFORT=low

# Consolidation -- final cross-source synthesis
CONSOLIDATION_MODEL=gpt-5-mini
CONSOLIDATION_MAX_TOKENS=32768
CONSOLIDATION_TEMPERATURE=
CONSOLIDATION_REASONING_EFFORT=low

# =============================================================================
# DATABASE
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbc_intel
DB_USER=your_username
DB_PASSWORD=
DB_SCHEMA=u_pipeline

# =============================================================================
# EMBEDDING
# =============================================================================

EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# =============================================================================
# SEARCH PARAMETERS
# =============================================================================

SEARCH_TOP_K=20
SEARCH_BM25_TOP_K=20
SEARCH_BM25_TERM_CAP=6
SEARCH_KEYWORD_MATCH_LIMIT=50
SEARCH_ENTITY_MATCH_LIMIT=10
ORCHESTRATOR_MAX_WORKERS=4

# =============================================================================
# SCORE WEIGHTS (must sum to 1.0)
# =============================================================================

WEIGHT_CONTENT_VECTOR=0.25
WEIGHT_HYDE_VECTOR=0.20
WEIGHT_SUBQUERY_VECTOR=0.15
WEIGHT_KEYWORD_VECTOR=0.10
WEIGHT_SECTION_SUMMARY=0.10
WEIGHT_BM25=0.12
WEIGHT_KEYWORD_ARRAY=0.07
WEIGHT_ENTITY_ARRAY=0.01

# =============================================================================
# THRESHOLDS
# =============================================================================

SMALL_DOC_TOKEN_THRESHOLD=80000
RERANK_PREVIEW_MAX_TOKENS=120
RERANK_CANDIDATE_LIMIT=30
RERANK_MIN_KEEP=10
EXPAND_SECTION_TOKEN_THRESHOLD=6000
EXPAND_SUBSECTION_TOKEN_THRESHOLD=3000
EXPAND_NEIGHBOR_COUNT=4

# =============================================================================
# RESEARCH
# =============================================================================

RESEARCH_MAX_ITERATIONS=3
RESEARCH_ADDITIONAL_SEARCH_TOP_K=10

# =============================================================================
# TRACING
# =============================================================================

RETRIEVAL_TRACE_ROOT=./traces
