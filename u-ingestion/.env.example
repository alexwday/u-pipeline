# =============================================================================
# AUTHENTICATION
# =============================================================================

# Mode: "oauth" or "api_key"
AUTH_MODE=api_key

# API key auth (when AUTH_MODE=api_key)
OPENAI_API_KEY=sk-...

# OAuth auth (when AUTH_MODE=oauth)
OAUTH_TOKEN_ENDPOINT=https://auth.example.com/oauth2/token
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_SCOPE=

# =============================================================================
# LLM ENDPOINT
# =============================================================================

LLM_ENDPOINT=https://api.openai.com/v1

# =============================================================================
# LLM MODELS — per stage
# Each stage uses {STAGE}_MODEL, {STAGE}_MAX_TOKENS,
# {STAGE}_TEMPERATURE, and optionally
# {STAGE}_REASONING_EFFORT and {STAGE}_VERBOSITY.
#
# TEMPERATURE: Leave blank for models that don't support it (gpt-5-*, o-series)
# REASONING_EFFORT: Controls thinking depth (minimal, low, medium, high).
#   - "minimal" for extraction/routing/transforms (lowest latency)
#   - "low" for classification and simple decisions
#   - "medium"/"high" for analysis requiring multi-step reasoning
#   - Leave blank for default model behavior
# VERBOSITY: Controls output completeness (low, medium, high).
#   - "high" for OCR/transcription tasks — literal rendering, precise formatting
#   - Leave blank for default model behavior
# =============================================================================

# Startup — connection validation only
STARTUP_MODEL=gpt-5-mini
STARTUP_MAX_TOKENS=1000
STARTUP_TEMPERATURE=
STARTUP_REASONING_EFFORT=
STARTUP_VERBOSITY=

# Token counting model for tokenization and chunking
TOKENIZER_MODEL=o200k_base

# Extraction — vision-based page content extraction
EXTRACTION_MODEL=gpt-5-mini
EXTRACTION_MAX_TOKENS=16000
EXTRACTION_TEMPERATURE=
EXTRACTION_REASONING_EFFORT=minimal
EXTRACTION_VERBOSITY=high

# Classification is deterministic and does not use model settings

# Chunking
CHUNKING_MODEL=gpt-5-mini
CHUNKING_MAX_TOKENS=4000
CHUNKING_TEMPERATURE=
CHUNKING_REASONING_EFFORT=low
CHUNKING_VERBOSITY=

# =============================================================================
# DATABASE
# =============================================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=rbc_intel
DB_USER=your_username
DB_PASSWORD=
DB_SCHEMA=u_pipeline

# =============================================================================
# PIPELINE
# =============================================================================

# Absolute path to the data sources root directory
DATA_SOURCE_PATH=/path/to/data/sources

# Number of archive zips and log files to retain
RETENTION_COUNT=31

# Comma-separated list of accepted file extensions (no dots)
ACCEPTED_FILETYPES=pdf,docx,pptx,xlsx

# Document cache persistence
DOCUMENT_CACHE_ROOT=
NON_CURRENT_VERSION_RETENTION_COUNT=1

# Max parallel file processing threads
MAX_WORKERS=4
EXTRACTION_PAGE_WORKERS=4

# DPI scale for rendering pages to images (higher = sharper)
VISION_DPI_SCALE=2.0

# Vision retry settings
PDF_VISION_MAX_RETRIES=3
PDF_VISION_RETRY_DELAY_SECONDS=2.0
DOCX_VISION_MAX_RETRIES=3
DOCX_VISION_RETRY_DELAY_SECONDS=2.0
PPTX_VISION_MAX_RETRIES=3
PPTX_VISION_RETRY_DELAY_SECONDS=2.0
XLSX_VISION_MAX_RETRIES=3
XLSX_VISION_RETRY_DELAY_SECONDS=2.0

# Chunking settings
CHUNKING_EMBEDDING_TOKEN_LIMIT=8192
CHUNKING_TRUNCATION_TOKEN_LIMIT=80000
CHUNKING_MAX_RETRIES=2
CHUNKING_MD_BATCH_SIZE=100
CHUNKING_XLSX_BATCH_SIZE=50
CHUNKING_XLSX_HEADER_ROWS=5
CHUNKING_XLSX_OVERLAP_ROWS=3

# =============================================================================
# ENRICHMENT STAGES
# =============================================================================

# Enrichment: Document metadata
DOC_METADATA_MODEL=gpt-5-mini
DOC_METADATA_MAX_TOKENS=4000
DOC_METADATA_TEMPERATURE=
DOC_METADATA_REASONING_EFFORT=low
DOC_METADATA_VERBOSITY=
DOC_METADATA_CONTEXT_BUDGET=30000

# Enrichment: Section detection
SECTION_DETECTION_MODEL=gpt-5-mini
SECTION_DETECTION_MAX_TOKENS=4000
SECTION_DETECTION_TEMPERATURE=
SECTION_DETECTION_REASONING_EFFORT=medium
SECTION_DETECTION_VERBOSITY=
SECTION_DETECTION_BATCH_BUDGET=80000
SUBSECTION_TOKEN_THRESHOLD=15000

# Enrichment: Content extraction (keywords/entities)
CONTENT_EXTRACTION_MODEL=gpt-5-mini
CONTENT_EXTRACTION_MAX_TOKENS=8000
CONTENT_EXTRACTION_TEMPERATURE=
CONTENT_EXTRACTION_REASONING_EFFORT=low
CONTENT_EXTRACTION_VERBOSITY=
CONTENT_EXTRACTION_BATCH_BUDGET=60000

# Enrichment: Section summary
SECTION_SUMMARY_MODEL=gpt-5-mini
SECTION_SUMMARY_MAX_TOKENS=4000
SECTION_SUMMARY_TEMPERATURE=
SECTION_SUMMARY_REASONING_EFFORT=medium
SECTION_SUMMARY_VERBOSITY=
SECTION_SUMMARY_BATCH_BUDGET=80000

# Enrichment: Document summary
DOC_SUMMARY_MODEL=gpt-5-mini
DOC_SUMMARY_MAX_TOKENS=4000
DOC_SUMMARY_TEMPERATURE=
DOC_SUMMARY_REASONING_EFFORT=high
DOC_SUMMARY_VERBOSITY=

# Enrichment: Embedding
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072
EMBEDDING_BATCH_SIZE=20
